<!DOCTYPE html>
<html lang="ru" class="h-full scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- SEO Title -->
  <title>Навесы из поликарбоната в Крыму — изготовление и установка в Симферополе</title>

  <!-- SEO Description -->
  <meta name="description" content="Производство и монтаж навесов из поликарбоната в Крыму. Работаем в Симферополе и по всему региону. Бесплатный замер и расчет.">

  <!-- Google Search Console -->
  <meta name="google-site-verification" content="ВАШ_КОД_ОТ_GOOGLE">

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/favicon.png">

  <!-- Vite assets -->
  <%= vite_client_tag %>

  <!-- Основные ассеты приложения -->
  <%= vite_stylesheet_tag 'application' %>
  <%= vite_javascript_tag 'application' %>

  <!-- Админские ассеты (только для админ-разделов) -->
  <% if admin_section? %>
    <%= vite_javascript_tag 'active_admin' %>
    <%= vite_stylesheet_tag 'active_admin' %>
  <% end %>

  <!-- Preload critical resources -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
</head>

<body class="<%= body_classes %>"
      data-controller="<%= body_data_controllers %>">

<!-- Основной сайт -->
<%# unless admin_section? %>
<%#= render "shared/header" %>
<%# end %>

<!-- Основной контент -->
<main class="<%= main_classes %>">
  <%= yield %>
</main>

<!-- Футер (только для основного сайта) -->
<%# unless admin_section? %>
<%#= render "shared/footer" %>
<%# end %>

<!-- Модалки и уведомления (только для основного сайта) -->
<% unless admin_section? %>
  <%= render "shared/lead_modal" %>
  <div class="fixed bottom-4 right-4 z-50 space-y-2" id="toast-container"></div>
<% end %>
</body>
</html>